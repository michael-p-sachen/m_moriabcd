{
  "name": "m_moriabcd",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "dev:oxygen": "shopify hydrogen dev",
    "build": "npm run build:spa && npm run prepare:oxygen && npm run build:oxygen",
    "build:spa": "tsc -b && vite build",
    "prepare:oxygen": "node scripts/prepare-oxygen.mjs",
    "build:oxygen": "shopify hydrogen build",
    "preview:oxygen": "npm run build && shopify hydrogen preview",
    "upload:files": "node --env-file=.env scripts/upload-to-shopify.mjs",
    "upload:r2": "node --env-file=.env scripts/upload-to-r2.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0",
      "prettier --write"
    ],
    "*.{js,jsx,css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@remix-run/react": "1.19.1",
    "@shopify/cli": "3.47.5",
    "@shopify/cli-hydrogen": "5.1.0",
    "@shopify/hydrogen": "2023.7.0",
    "@shopify/remix-oxygen": "^1.1.1",
    "isbot": "^3.6.6",
    "pdfjs-dist": "5.4.296",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/lib-storage": "^3.1045.0",
    "@eslint/js": "^9.39.4",
    "@remix-run/dev": "1.19.1",
    "@smithy/node-http-handler": "^4.7.1",
    "@types/node": "^24.12.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "prettier": "^3.5.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  },
  "overrides": {
    "zod": "^3.25.0"
  }
}
